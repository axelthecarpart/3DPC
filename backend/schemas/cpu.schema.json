{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CPU JSON Schema",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "specifications": {
      "type": "object",
      "properties": {
        "cores": {
          "type": "object",
          "properties": {
            "total": { "type": "number" },
            "performance": { "type": "number" },
            "efficiency": { "type": ["number", "null"] },
            "threads": { "type": "number" }
          },
          "required": ["total", "performance", "threads"]
        },
        "clocks": {
          "type": "object",
          "properties": {
            "performance": {
              "type": "object",
              "properties": {
                "base": { "type": "number" },
                "boost": { "type": "number" }
              },
              "required": ["base", "boost"]
            }
          },
          "required": ["performance"]
        },
        "cache": {
          "type": "object",
          "properties": {
            "l2": { "type": "number" },
            "l3": { "type": "number" }
          },
          "required": ["l2", "l3"]
        },
        "integratedGraphics": {
          "type": "object",
          "properties": {
            "model": { "type": "string", "enum": ["None", "AMD Radeon Graphics", "Intel Xe Graphics"] }
          },
          "required": ["model"]
        },
        "memory": {
          "type": "object",
          "properties": {
            "max": { "type": "number" },
            "types": {
              "type": "array",
              "items": { "type": "string", "enum": ["DDR3", "DDR4", "DDR5"] },
              "minItems": 1,
              "uniqueItems": true
            }
          },
          "required": ["max", "types"]
        },
        "multithreading": { "type": "boolean" },
        "pcieSupport": {
          "type": "object",
          "properties": {
            "version": { "type": "array", "items": { "type": "number" } },
            "lanes": { "type": "number" },
            "usable": { "type": "number" }
          },
          "required": ["version", "lanes", "usable"]
        },
        "lithography": { "type": "string" }
      },
      "required": ["cores", "clocks", "cache", "integratedGraphics", "memory", "multithreading", "pcieSupport", "lithography"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "manufacturer": { "type": "string", "enum": ["AMD", "Intel"] },
        "ecc": {
          "type": "object",
          "properties": {
            "support": { "type": "boolean" },
            "needMotherboard": { "type": "boolean" }
          },
          "required": ["support", "needMotherboard"]
        },
        "tdp": {
          "type": "object",
          "properties": {
            "base": { "type": "number" },
            "max": { "type": "number" }
          },
          "required": ["base"]
        },
        "microarchitecture": { "type": "string", "enum": ["Zen 5", "Zen 4", "Arrow Lake", "Raptor Lake Refresh", "Raptor Lake"] },
        "socket": { "type": "string", "enum": ["AM5", "LGA 1700", "LGA 1851"] }
      },
      "required": ["name", "manufacturer", "ecc", "tdp", "microarchitecture", "socket"]
    },
    "links": {
      "type": "object",
      "properties": {
        "productPage": { "type": "string", "format": "uri" },
        "sellers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            },
            "required": ["name"]
          }
        }
      },
      "required": ["productPage", "sellers"]
    }
  },
  "required": ["id", "specifications", "metadata", "links"],
  "additionalProperties": false
}
